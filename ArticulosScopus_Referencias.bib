@ARTICLE{Zhang20251394,
	author = {Zhang, Ziyue and Yu, Yongbin and Wang, Xiangxiang and Feng, Xiao and Li, Yuze and Shen, Jiarun and Tashi, Dorje and Zhang, Jin and Yeshi, Lobsang and Li, Lei and Tashi, Nyima and Cai, Jingye},
	title = {Tibetan Few-Shot Learning Model With Deep Contextualised Two-Level Word Embeddings},
	year = {2025},
	journal = {CAAI Transactions on Intelligence Technology},
	volume = {10},
