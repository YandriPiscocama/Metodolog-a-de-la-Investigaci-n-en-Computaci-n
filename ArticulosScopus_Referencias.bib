@ARTICLE{Selvaraj2024,
	author = {Selvaraj, Sarojini and Panjanathan, Rukmani},
	title = {WordDGA: Hybrid Knowledge-Based Word-Level Domain Names Against DGA Classifiers and Adversarial DGAs},
	year = {2024},
	journal = {Informatics},
