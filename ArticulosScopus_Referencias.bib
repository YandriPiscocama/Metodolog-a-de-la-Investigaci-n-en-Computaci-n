@ARTICLE{Dehghan2023,
	author = {Dehghan, Somaiyeh and Amasyali, Mehmet Fatih},
	title = {SelfCCL: Curriculum Contrastive Learning by Transferring Self-Taught Knowledge for Fine-Tuning BERT},
