@ARTICLE{Li20263382,
	author = {Li, Zhaoyang and Yang, Qianqian and Xiong, Zehui and Shi, Zhiguo and Quek, Tony Q.S.},
	title = {Bridging the Modality Gap: Enhancing Channel Prediction With Semantically Aligned LLMs and Knowledge Distillation},
	year = {2026},
	journal = {IEEE Journal on Selected Areas in Communications},
	volume = {44},
