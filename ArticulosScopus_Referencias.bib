@CONFERENCE{Li2025496,
	author = {Li, You},
	title = {Research on Adaptive Learning Path Optimization Algorithm for Public English Based on Natural Language Processing},
	year = {2025},
	journal = {Proceedings - 2025 Asia-Europe Conference on Cybersecurity, Internet of Things and Soft Computing, CITSC 2025},
	pages = {496 - 502},
	doi = {10.1109/CITSC64390.2025.00096},
	url = {https://www.scopus.com/pages/publications/105002689429?origin=resultslist},
	abstract = {In this paper, a learning path optimization algorithm based on natural language processing (NLP) and adaptive learning system is proposed to improve the personalized and intelligent level of public English learning. The algorithm first constructs a semantic understanding model based on word embedding technology (such as Word2Vec), and calculates the semantic similarity between words by mapping them to a high-dimensional vector space, so as to realize the deep parsing of the learning content. Through deep learning methods, especially long short-term memory network (LSTM), the model can effectively capture learners' text input, deeply analyze their language expression and learning state, and accurately identify learners' knowledge points and potential learning disabilities. In terms of learning path optimization, a domain model-based path generation and optimization mechanism is constructed by combining adaptive learning system. By interacting with the learning environment, the system adjusts the decision-making strategy according to the learner's learning progress feedback in real time, and optimizes the learning path in each iteration to ensure the efficiency and accuracy of personalized recommendation. The experimental results show that the proposed algorithm is significantly better than the traditional adaptive learning model in terms of learning effect, path recommendation accuracy and learner engagement, which shows its wide application potential in practical education scenarios. © 2025 IEEE.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Pan2024,
	author = {Pan, Jeng-Shyang and Wang, Xiao and Yang, Dongqiang and Li, Ning and Huang, Kevin and Chu, Shu-Chuan},
	title = {Flexible margins and multiple samples learning to enhance lexical semantic similarity},
	year = {2024},
	journal = {Engineering Applications of Artificial Intelligence},
	volume = {133},
	pages = {},
	doi = {10.1016/j.engappai.2024.108275},
	url = {https://www.scopus.com/pages/publications/85188153947?origin=resultslist},
	abstract = {The advancement of deep learning and neural networks has led to the widespread adoption of neural word embeddings as a prominent lexical representation method in natural language processing. With the help of the neural language model trained by the contextual information of large scale text, the neural word embedding obtained by the neural language model captures more semantic correlation in the semantic space, while ignoring the semantic similarity. It will incur high computational cost and time costs during the training process of the model. To better inject semantic similarity into the distribution space and reduce time cost, we perform post processing learning of neural word embeddings using deep metric learning. This paper proposes a lexical enhancement method based on flexible margins and multiple samples learning. In this method, we embed the lexical entailment constraint relations into neural word embeddings. By categorizing the set of lexical constraints and penalizing the negative samples to different degrees according to the gap between categories, and allowing the positive and negative samples to learn from each other in the distributed space. The method we propose significantly improves neural word embeddings. By evaluating neural word embedded vocabulary similarity, the benchmark accuracy is improved to 75%. The method shows great competitiveness in text similarity tasks and text categorization tasks. These findings summarize research results and provide strong support for further applications. © 2024 Elsevier Ltd},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 3}
}

