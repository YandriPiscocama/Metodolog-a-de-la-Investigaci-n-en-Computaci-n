@ARTICLE{Elizabeth2026,
	author = {Elizabeth, M.J. and Hazari, Raju},
	title = {A language independent machine learning model for sentiment analysis and toxicity classification in code-mixed data},
	year = {2026},
	journal = {Natural Computing},
	volume = {25},
