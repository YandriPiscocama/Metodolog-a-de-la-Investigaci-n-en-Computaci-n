@ARTICLE{Bahaa202464446,
	author = {Bahaa, Ahmed and Kamal, Aya and Fahmy, Hanan and Ghoneim, Amr S.},
	title = {DB-CBIL: A DistilBert-Based Transformer Hybrid Model Using CNN and BiLSTM for Software Vulnerability Detection},
	year = {2024},
