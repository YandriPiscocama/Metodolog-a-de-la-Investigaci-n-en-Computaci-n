	note = {Cited by: 0; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{Ghanem20233697,
	author = {Ghanem, Razan and Erbay, Hasan},
	title = {Spam detection on social networks using deep contextualized word representation},
	year = {2023},
	journal = {Multimedia Tools and Applications},
	volume = {82},
