@CONFERENCE{Brinda2024,
	author = {Brinda, B.M. and Rajan, C. and Geetha, K.},
	title = {Detecting Evolving Fake News in Social Media by Leveraging Heterogeneous Deep Learning Model},
	year = {2024},
	journal = {2nd IEEE International Conference on Advances in Information Technology, ICAIT 2024 - Proceedings},
	pages = {},
	doi = {10.1109/ICAIT61638.2024.10690338},
	url = {https://www.scopus.com/pages/publications/85208827740?origin=resultslist},
	abstract = {A recent study revealed that fake articles spread considerably faster than factual content on Twitter, specifically at a 70% higher rate of retweets and reaching the first 1,500 users six times faster. This highlights the urgent need for scalable automated detection solutions to combat the pervasive threat of fake news online. While machine learning methods often rely solely on semantic text analysis, evolving fake news campaigns mimic genuine news, employing tactics like bot networks and sophisticated language imitation. This renders text-based meth- ods increasingly vulnerable. To address this challenge,we propose a heterogeneous deep learning model that incorporates richer information beyond text, specifically dissemination structure features from social networks. These features capture aspects like user interactions, sharing patterns, and network topology, providing valuable insights into the spread of information. Our model leverages the sentiment and affects the enriched Alt dataset for text analysis. Instead of using a popular language model called BERT, we explore alternative pre-trained language models like the Sentence Transformer, which focuses on capturing con- textual sentence embeddings, or the Universal Language Model (ULMFiT), which excels at understanding semantic relationships within text. Additionally, we consider spaCy, a versatile NLP library offering similar functionalities for text processing and feature extraction. While The Quint Dataset Challenge Dataset lacks sentiment annotations, it could be a potential alternative to Alt depending on research goals. This network-aware approach achieves an impressive 95.27% accuracy on The Boom Live dataset and demonstrates generalizability to The Quint dataset with 92.1% accuracy, highlighting its effectiveness in combatting evolving fake news tactics. © 2024 IEEE.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1}
}

@ARTICLE{YU2024259,
	author = {YU, Mingcheng and DANG, Yagu and WU, Qilin and JI, Xu and BI, Kexin},
	title = {Research on Automatic Scoring for English Essay Based on Multi-Scale Context},
	year = {2024},
	journal = {Jisuanji Gongcheng/Computer Engineering},
	volume = {50},
	number = {3},
	pages = {259 - 266},
	doi = {10.19678/j.issn.1000-3428.0067224},
	url = {https://www.scopus.com/pages/publications/85188891230?origin=resultslist},
	abstract = {Presently, the automatic scoring model for essays lacks extraction of semantic features from different context scales, and fails to calculate the degree of correlation between the topic of the essay from the sentence level. This study proposes a method MSC for automatic scoring of English esssay based on a multi-scale context. The method uses an XLNet English pre-training model to extract word and sentence embeddings from the original essay text,  accurately captures vector embeddings that match the context when processing long sequence texts, improves the quality of dynamic vector semantic representation, addresses the problem of polysemy, and extracts phrase level embeddings at different scales through a one-dimensional convolution module. The MSC network captures high-dimensional latent contextual semantic associations at the word, phrase, and sentence levels by combining Built-in Self-Attention Simple Recurrence Units（BSASRU） and global attention mechanisms. It uses sentence vectors to calculate semantic similarity with the essay topic and extracts topic level features. All features are input into the fusion layer and are automatically graded through a linear layer. The experimental results on the publicly available standard English essay scoring dataset ASAP demonstrate that the MSC model achieves an average Quadratic Weighted Kappa（QWK） value of 80.5%. Moreover, it achieves the best performance on multiple subsets, outperforming the deep learning automatic scoring model in experimental comparison, thereby proving its effectiveness in English essay automatic scoring tasks. © 2024, Editorial Office of Computer Engineering. All rights reserved.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 5}
}

