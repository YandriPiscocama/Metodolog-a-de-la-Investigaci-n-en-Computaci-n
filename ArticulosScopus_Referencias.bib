@ARTICLE{Muneer2025,
	author = {Muneer, Iqra and Shehzadi, Aysha and Ashraf, Muhammad Adnan and Nawab, Rao Muhammad Adeel},
	title = {Has machine paraphrasing skills approached humans? Detecting automatically and manually generated paraphrased cases},
	year = {2025},
