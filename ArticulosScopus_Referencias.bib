@CONFERENCE{Li20251384,
	author = {Li, Zhaoyang and Yang, Qianqian and Shi, Zhiguo and Xiong, Zehui and Quek, Tony Q. S.},
	title = {CSI-ALM: Enhancing Channel State Information Prediction with Semantically Aligned Large Language Models},
	year = {2025},
	journal = {Proceedings - IEEE Global Communications Conference, GLOBECOM},
	pages = {1384 - 1389},
	doi = {10.1109/GLOBECOM59602.2025.11432568},
	url = {https://www.scopus.com/pages/publications/105036328292?origin=resultslist},
	abstract = {Accurate channel prediction is essential in massive multiple-input multiple-output (m-MIMO) systems to enhance precoding performance and reduce the overhead of channel state information (CSI) feedback. However, existing methods often suffer from limited generalization capabilities and cumulative prediction errors, making it difficult to maintain high accuracy in dynamic wireless environments. Recently, large language models (LLMs) have demonstrated remarkable modeling and generalization abilities, and some studies have explored their application to channel prediction tasks. Nonetheless, existing research has largely overlooked the significant modality gap between the linguistic knowledge encoded in pretrained LLMs and the intrinsic characteristics of CSI, which can hinder the effectiveness of directly applying LLMs to this domain. To address this, we propose a novel channel prediction method that leverages pretrained corpora for semantic prompting and cross-modal alignment. Specifically, we design a cross-modal semantic alignment module that aligns CSI features with the linguistic feature space using a pretrained embedding corpus. In addition, we introduce a semantic prompting mechanism that identifies the most relevant word embeddings - based on maximum cosine similarity to CSI embeddings - to enrich the latent representation input to a fine-tuned LLM backbone, which then generates channel predictions. Extensive experimental results demonstrate that the proposed method significantly outperforms existing deep learning approaches, showing strong generalization in both few-shot and zero-shot scenarios. In particular, our method achieves a gain of over 1 dB compared to the state-of-the-art in time-division duplexing (TDD) communication scenarios. © 2025 IEEE.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

